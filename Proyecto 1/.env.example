# ===========================================
# PROYECTO-1-FULL-JP - Variables de entorno
# ===========================================
# Copiar a .env y ajustar valores según el entorno.
# cp .env.example .env

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=ml_user
MYSQL_PASSWORD=ml_password
MYSQL_DATABASE=ml_data
MYSQL_ROOT_PASSWORD=rootpassword

# --- MinIO ---
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET_MODELOS=modelos
MINIO_BUCKET_ARTEFACTOS=artefactos

# --- API de Datos (para Airflow) ---
API_DATOS_URL=http://api_datos:80

# --- Airflow ---
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin

# --- Jupyter ---
JUPYTER_TOKEN=jupyter
