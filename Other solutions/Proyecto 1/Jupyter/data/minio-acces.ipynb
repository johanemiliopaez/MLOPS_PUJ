   "source": [
    "import os\n",
    "from minio import Minio\n",
    "client = Minio(\n",
    "    \"minio:9000\",  # hostname:puerto\n",
    "    access_key=os.environ[\"MINIO_ACCESS_KEY\"],\n",
    "    secret_key=os.environ[\"MINIO_SECRET_KEY\"],\n",
    "    secure=False\n",
    ")\n",
    "for obj in client.list_objects(\"models\"):\n",
    "    print(obj.object_name)"
   ]
